{
  "name": "obsidian-math-chords",
  "version": "0.2.1",
  "description": "Type LaTeX math with keyboard shortcuts—fractions, Greek letters, integrals, and 100+ snippets (leader key + keys). Inline preview, display-math wrap. Settings UI in 70+ languages incl. Chinese.",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ichenh/obsidian-math-chords.git"
  },
  "bugs": {
    "url": "https://github.com/ichenh/obsidian-math-chords/issues"
  },
  "homepage": "https://github.com/ichenh/obsidian-math-chords#readme",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "seed": "node scripts/seed-yaml.cjs",
    "seed:locales": "node scripts/seed-locales.cjs"
  },
  "author": "CHEH Hua",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.26.3",
    "@types/node": "^20.11.0",
    "esbuild": "^0.28.1",
    "obsidian": "^1.5.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
